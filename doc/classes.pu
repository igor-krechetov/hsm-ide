@startuml

!theme plain
skinparam groupInheritance 2
skinparam Shadowing false
skinparam Class {
    BackgroundColor White
    ArrowColor #0078d7
    BorderColor #0078d7
}

title HSM IDE Class Diagram

package "Model" {
  class StateMachineModel {
    + addState()
    + removeState()
    + addTransition()
    + validate()
    + serialize()
  }

  class StateMachineEntity {
    + getId(): string
    + getName(): string
    + getParent(): StateMachineEntity
  }

  class State {
    + getChildStates()
    + addTransition()
  }

  class Transition {
    + getSource()
    + getTarget()
    + getEvent()
  }

  class FinalState
  class HistoryState
  class InitialState

  StateMachineEntity <|-- State
  StateMachineEntity <|-- Transition
  State <|-- FinalState
  State <|-- HistoryState
  State <|-- InitialState

  StateMachineModel "1" *-- "*" StateMachineEntity : contains
}

package "View" {
  class MainWindow {
    + setupUi()
    + connectSignals()
  }

  class HsmGraphicsView {
    + addElement()
    + removeElement()
    + clearScene()
  }

  class HsmElement {
    + elementType(): HsmElementType
    + elementRect(): QRectF
    + init()
    + updateBoundingRect()
  }

  class HsmResizableElement {
    + createBoundaryGrips()
    + updateGripsPosition()
    + setGripVisibility()
  }

  class HsmConnectableElement {
    + addTransition()
    + createConnectionArrows()
    + removeConnectionArrows()
    + updateConnectionArrowsPos()
  }

  class HsmEntryPointElement
  class HsmExitPointElement
  class HsmFinalElement
  class HsmHistoryElement
  class HsmStartElement
  class HsmStateElement

  MainWindow "1" *-- "1" HsmGraphicsView : contains
  HsmElement <|-- HsmResizableElement
  HsmResizableElement <|-- HsmConnectableElement
  HsmConnectableElement <|-- HsmEntryPointElement
  HsmConnectableElement <|-- HsmExitPointElement
  HsmConnectableElement <|-- HsmFinalElement
  HsmConnectableElement <|-- HsmHistoryElement
  HsmConnectableElement <|-- HsmStartElement
  HsmConnectableElement <|-- HsmStateElement

  class HsmTransition {
    + beginConnection()
    + connectElements()
    + removeConnection()
    + recalculateLine()
  }
  HsmElement <|-- HsmTransition
}

package "Controller" {
  class MainEditorController {
    + newProject()
    + openProject()
    + saveProject()
    + addState()
    + addTransition()
  }

  class ProjectController {
    + loadProject()
    + saveProject()
    + getRecentProjects()
  }

  MainEditorController "1" *-- "1" ProjectController : uses
}

package "Supporting Elements" {
  class ElementGripItem
  class ElementBoundaryGripItem
  class ElementConnectionArrow
  ElementGripItem <|-- ElementBoundaryGripItem

  class HsmElementsFactory {
    + createElement()
    + createTransition()
  }

  HsmResizableElement "1" *-- "0..8" ElementBoundaryGripItem : boundary grips
  HsmConnectableElement "1" -- "0..*" HsmTransition: transitions
  HsmElementsFactory ..> HsmElement : creates
}

' Model-View-Controller Relationships
MainEditorController --> StateMachineModel : manipulates
MainEditorController --> MainWindow : updates
StateMachineModel ..> MainEditorController : notifies
MainWindow ..> MainEditorController : sends events

' Element Connections
HsmTransition "1" --> "1" HsmConnectableElement : from
HsmTransition "1" --> "1" HsmConnectableElement : to

' View-Model Mapping
note "View elements represent\nmodel entities" as N1
HsmStateElement ..|> State : represents
HsmTransition ..|> Transition : represents
HsmFinalElement ..|> FinalState : represents

@enduml

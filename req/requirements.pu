        .done {
            BackgroundColor LightGreen
        }
        .prio_low {
            BackgroundColor SkyBlue
        }
        .todo {
            BackgroundColor Salmon
        }
        .partial {
            BackgroundColor LightYellow
        }
    }
</style>

